<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - CyberRiskLingo</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>

<body>

    @{
        var user = Context.Session.GetString("Username");
    }

    @if (!string.IsNullOrEmpty(user))
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    CyberRiskLingo
                </a>

                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "CyberRisk")">
                                Manage Risks
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Create", "CyberRisk")">
                                Add Risk
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Privacy", "Home")">
                                Privacy
                            </a>
                        </li>

                    </ul>

                    <!-- Logout -->
                    <form asp-controller="Login" asp-action="Logout" method="post">
                        <button class="btn btn-outline-light btn-sm">
                            Logout (@user)
                        </button>
                    </form>
                </div>
            </div>
        </nav>
    }

    <div class="container">
        @RenderBody()
    </div>

    <footer class="text-center mt-4">
        <p>&copy; 2026 CyberRiskLingo</p>
    </footer>

    @RenderSection("Scripts", required: false)

</body>
</html>