@model CyberRiskAPI.Models.CyberRisk
@{
    ViewData["Title"] = "Risk Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Risk Details</h2>

<div class="card p-3">
    <p><strong>ID:</strong> @Model.Id</p>
    <p><strong>Risk Name:</strong> @Model.RiskName</p>
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Asset:</strong> @Model.AssetName</p>
    <p><strong>Industry:</strong> @Model.Industry</p>
    <p><strong>Category:</strong> @Model.Category</p>
    <p><strong>Impact:</strong> @Model.Impact</p>
    <p><strong>Likelihood:</strong> @Model.Likelihood</p>
    <p><strong>Score:</strong> @Model.Score</p>
    <p>
        <strong>Risk Level:</strong>
        <span class="badge
            @(Model.RiskLevel == "High" ? "bg-danger" :
                            Model.RiskLevel == "Medium" ? "bg-warning text-dark" :
                            "bg-success")">
            @Model.RiskLevel
        </span>
    </p>
    <p><strong>Mitigation:</strong> @Model.MitigationStrategy</p>
</div>

<div class="mt-3">
    <a class="btn btn-primary"
           asp-action="Edit"
           asp-route-id="@Model.Id">
        Edit
    </a>

    <a class="btn btn-danger"
           asp-action="Delete"
           asp-route-id="@Model.Id">
        Delete
    </a>

    <a class="btn btn-secondary"
           asp-action="Index">
        Back to List
    </a>
</div>